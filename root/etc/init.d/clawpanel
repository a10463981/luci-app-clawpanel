#!/bin/sh /etc/rc.common
# luci-app-clawpanel - init script for ClawPanel

USE_PROCD=0
START=99
STOP=10

EXTRA_COMMANDS="setup status_service"
EXTRA_HELP="    setup            install ClawPanel\n    status_service   show service status"

_load_uci() {
    CP_BASE_PATH="$(uci -q get clawpanel.main.install_path || echo '')"
    if [ -z "$CP_BASE_PATH" ] || [ "${CP_BASE_PATH#/}" = "$CP_BASE_PATH" ]; then
        echo "ClawPanel: install_path not set, run clawpanel-env setup first"
        return 1
    fi
    CP_INSTALL_PATH="${CP_BASE_PATH}/clawpanel"
    CP_DATA="${CP_INSTALL_PATH}/data"
    CP_BIN="${CP_INSTALL_PATH}/clawpanel"
    CP_OPENCLAW_DIR="$(uci -q get clawpanel.main.openclaw_dir || echo '')"
    if [ -z "$CP_OPENCLAW_DIR" ] || [ "${CP_OPENCLAW_DIR#/}" = "$CP_OPENCLAW_DIR" ]; then
        CP_OPENCLAW_DIR="${CP_BASE_PATH}/.openclaw"
    fi
    return 0
}

start_service() {
    _load_uci || return 1

    config_load clawpanel
    local enabled port
    config_get enabled main enabled "0"
    config_get port main port "19527"

    [ "$enabled" = "1" ] || {
        echo "ClawPanel: disabled in UCI (enabled=0)"
        return 0
    }

    [ -x "$CP_BIN" ] || {
        echo "ClawPanel: binary not found at $CP_BIN"
        return 1
    }

    # Ensure directories exist
    mkdir -p "$CP_DATA" "$CP_OPENCLAW_DIR" 2>/dev/null

    # Sanitise port
    port=$(echo "$port" | tr -cd '0-9')
    [ -z "$port" ] && port=19527

    # Only write clawpanel.json if it doesn't exist yet, to preserve user-modified values
    if [ ! -f "$CP_DATA/clawpanel.json" ]; then
        mkdir -p "$CP_DATA" 2>/dev/null
        printf '{\n' > "$CP_DATA/clawpanel.json"
        printf '  "port": %s,\n' "$port" >> "$CP_DATA/clawpanel.json"
        printf '  "dataDir": "%s",\n' "$CP_DATA" >> "$CP_DATA/clawpanel.json"
        printf '  "openClawDir": "%s",\n' "$CP_OPENCLAW_DIR" >> "$CP_DATA/clawpanel.json"
        printf '  "openClawApp": "%s",\n' "${CP_INSTALL_PATH}/app" >> "$CP_DATA/clawpanel.json"
        printf '  "openClawWork": "%s",\n' "${CP_INSTALL_PATH}/work" >> "$CP_DATA/clawpanel.json"
        printf '  "edition": "pro",\n' >> "$CP_DATA/clawpanel.json"
        printf '  "jwtSecret": "clawpanel-secret-change-me",\n' >> "$CP_DATA/clawpanel.json"
        printf '  "adminToken": "clawpanel",\n' >> "$CP_DATA/clawpanel.json"
        printf '  "debug": false\n' >> "$CP_DATA/clawpanel.json"
        printf '}\n' >> "$CP_DATA/clawpanel.json"
    fi

    # Stop any existing instances first
    stop_service

    echo "Starting ClawPanel: $CP_BIN (data=$CP_DATA, port=$port)"

    # Use bash -c to background (nohup doesn't exist on iStoreOS)
    (
        export HOME="/root"
        /bin/bash -c "$CP_BIN >> /tmp/clawpanel.log 2>&1 &"
    )

    # Brief wait then verify port is listening
    local i=0
    while [ $i -lt 20 ]; do
        if netstat -tulnp 2>/dev/null | grep -q ":${port} "; then
            echo "ClawPanel started: port=$port"
            return 0
        fi
        sleep 1
        i=$((i + 1))
    done

    echo "ClawPanel may have started but port $port not yet visible"
    return 0
}

stop_service() {
    _load_uci 2>/dev/null || true

    local port
    port=$(uci -q get clawpanel.main.port || echo "19527")
    port=$(echo "$port" | tr -cd '0-9')
    [ -z "$port" ] && port=19527

    # Kill by process name (covers both main and updater subprocesses)
    for pid in $(pgrep -f "clawpanel" 2>/dev/null); do
        kill "$pid" 2>/dev/null
    done

    # Wait for port to be released
    local i=0
    while [ $i -lt 15 ]; do
        if ! netstat -tulnp 2>/dev/null | grep -q ":${port} " 2>/dev/null; then
            break
        fi
        sleep 1
        i=$((i + 1))
    done
    return 0
}

reload_service() {
    stop_service
    sleep 1
    start_service
}

status_service() {
    _load_uci 2>/dev/null || true

    local port
    port=$(uci -q get clawpanel.main.port || echo "19527")
    local enabled
    enabled=$(uci -q get clawpanel.main.enabled || echo "0")

    echo "=== ClawPanel Status ==="
    echo "enabled: $enabled"
    echo "install_path: $CP_BASE_PATH"
    echo "data_dir: $CP_DATA"
    echo "openclaw_dir: $CP_OPENCLAW_DIR"
    echo "binary: $CP_BIN"
    echo "port: $port"
    if [ -x "$CP_BIN" ]; then
        echo "binary_version: $("$CP_BIN" --version 2>/dev/null | head -1)"
    else
        echo "binary: not found"
    fi
    if netstat -tulnp 2>/dev/null | grep -q ":${port} " 2>/dev/null; then
        echo "status: RUNNING"
    else
        echo "status: NOT running"
    fi
}
