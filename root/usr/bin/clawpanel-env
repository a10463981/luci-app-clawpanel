#!/bin/sh
#===========================================================
#  clawpanel-env — ClawPanel 安装脚本 v3
#  统一目录: /Configs/clawpanel /Configs/openclaw /Configs/.openclaw
#  Node.js: 系统级安装（/usr/local/bin/node）
#===========================================================
set -e

# 颜色
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'
BOLD='\033[1m'

log()   { echo "${GREEN}[✓]${NC} $1"; }
info()  { echo "${BLUE}[ℹ]${NC} $1"; }
warn()  { echo "${YELLOW}[!]${NC} $1"; }
err()   { echo "${RED}[✗]${NC} $1" >&2; }
step()  { echo ""; echo "${CYAN}═══ $1 ═══${NC}"; }
done_() { echo "${GREEN}[✓]${NC} $1 完成"; }
pr()    { echo "${BLUE}▸${NC} $1"; }

#===========================================================
# 全局变量
#===========================================================
CP_BASE_PATH="${CP_BASE_PATH:-}"
CP_VERSION="${CP_VERSION:-latest}"
ARCH="$(uname -m)"

case "$ARCH" in
    aarch64|arm64) TARGET_ARCH="aarch64" ;;
    x86_64)        TARGET_ARCH="x64" ;;
    armv7l|armv7)  TARGET_ARCH="armv7l" ;;
    armv6l|armv6)  TARGET_ARCH="armv6l" ;;
    *)             err "不支持的架构: $ARCH"; exit 1 ;;
esac

# /Configs 目录结构（统一存放）
CONFIGS_DIR=""          # /mnt/sda1/Configs
CLAWPANEL_DIR=""        # /mnt/sda1/Configs/clawpanel
CLAWPANEL_DATA=""       # /mnt/sda1/Configs/clawpanel/data
OPENCLAW_DIR=""         # /mnt/sda1/Configs/openclaw
OPENCLAW_DATA=""        # /mnt/sda1/Configs/.openclaw
OPENCLAW_WORK=""        # /mnt/sda1/Configs/.openclaw-work
NODE_PREFIX="/usr/local" # Node.js 安装到系统全局路径
CP_PORT="19527"

#===========================================================
# 工具函数
#===========================================================
check_disk() {
    local path="$1"
    local need_mb="${2:-500}"
    if [ ! -d "$path" ]; then
        err "路径不存在: $path"
        return 1
    fi
    local avail_mb
    avail_mb=$(df -m "$path" 2>/dev/null | tail -1 | awk '{print $4}')
    avail_mb=${avail_mb:-0}
    if [ "$avail_mb" -lt "$need_mb" ]; then
        err "磁盘空间不足: 可用 ${avail_mb}MB，需要 ${need_mb}MB"
        return 1
    fi
    log "磁盘空间: ${avail_mb}MB 可用 ✓"
    return 0
}

is_elf() {
    [ -f "$1" ] || return 1
    local magic
    magic=$(od -An -tx1 -N4 "$1" 2>/dev/null | tr -d ' \n\r')
    [ "$magic" = "7f454c46" ] && return 0
    # Fallback: 文件大于 20MB 视为有效二进制
    local sz
    sz=$(wc -c < "$1" 2>/dev/null || echo 0)
    [ -n "$sz" ] && [ "$sz" -gt 20000000 ]
}

get_arch() {
    echo "$TARGET_ARCH"
}

#===========================================================
# 第一步: 检查环境 + 初始化路径
#===========================================================
clear
echo "╔══════════════════════════════════════════════════╗"
echo "║   ClawPanel 安装脚本 v3                         ║"
echo "║   /Configs 统一目录结构                         ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""

[ "$(id -u)" = "0" ] || { err "必须以 root 用户运行"; exit 1; }
info "架构: $ARCH → $TARGET_ARCH"
info "时间: $(date '+%Y-%m-%d %H:%M:%S')"

# 检查 CP_BASE_PATH
if [ -z "$CP_BASE_PATH" ]; then
    err "CP_BASE_PATH 未设置（请从 LuCI 安装向导调用）"
    exit 1
fi
CP_BASE_PATH="${CP_BASE_PATH%/}"  # 去掉末尾斜杠

# 检查是否为系统路径（禁止）
case "$CP_BASE_PATH" in
    /|/overlay|/rom|/boot|/proc|/sys|/dev|/opt|/tmp|/var|/etc|/root|/usr|/bin|/sbin|/lib)
        err "禁止使用系统路径: $CP_BASE_PATH"
        exit 1 ;;
esac

# 验证目录存在且可用
check_disk "$CP_BASE_PATH" 500 || exit 1

# 初始化 /Configs 目录结构
CONFIGS_DIR="${CP_BASE_PATH}/Configs"
CLAWPANEL_DIR="${CONFIGS_DIR}/clawpanel"
CLAWPANEL_DATA="${CLAWPANEL_DIR}/data"
OPENCLAW_DIR="${CONFIGS_DIR}/openclaw"
OPENCLAW_DATA="${CONFIGS_DIR}/.openclaw"
OPENCLAW_WORK="${CONFIGS_DIR}/.openclaw-work"

log "存储根目录: $CP_BASE_PATH"
log "Configs 目录: $CONFIGS_DIR"

#===========================================================
# 第二步: 创建 /Configs 目录结构
#===========================================================
step "创建目录结构"

pr "创建 /Configs 目录..."
mkdir -p "$CONFIGS_DIR" "$CLAWPANEL_DIR" "$CLAWPANEL_DATA"
mkdir -p "$OPENCLAW_DIR" "$OPENCLAW_DATA" "$OPENCLAW_WORK"
done_ "目录结构"

echo ""
echo "  ${CONFIGS_DIR}/"
echo "  ├── clawpanel/          ← ClawPanel 程序"
echo "  │    ├── data/          ← 配置 + 数据"
echo "  │    └── clawpanel      ← Go 二进制"
echo "  ├── openclaw/           ← OpenClaw npm 包"
echo "  └── .openclaw/            ← OpenWrt 工作区"
echo "  └── .openclaw-work/    ← OpenClaw 运行时"

#===========================================================
# 第三步: 安装 Node.js（系统级）
#===========================================================
step "安装 Node.js（系统级）"

# 检查是否已有可用的 Node.js
_detect_node() {
    # 1. PATH 中的 node
    local np
    np=$(command -v node 2>/dev/null)
    if [ -n "$np" ] && [ -x "$np" ]; then
        echo "$np"
        return 0
    fi
    # 2. /usr/local/bin/node
    if [ -x "/usr/local/bin/node" ]; then
        echo "/usr/local/bin/node"
        return 0
    fi
    # 3. /usr/bin/node
    if [ -x "/usr/bin/node" ]; then
        echo "/usr/bin/node"
        return 0
    fi
    return 1
}

EXISTING_NODE=$(_detect_node)
if [ -n "$EXISTING_NODE" ]; then
    local ver
    ver=$($EXISTING_NODE --version 2>/dev/null)
    info "检测到已有 Node.js: $ver"
    local major
    major=$(echo "$ver" | tr -d 'v' | cut -d. -f1)
    if [ "$major" -ge 18 ]; then
        log "版本满足要求，跳过安装"
    else
        warn "版本过低 ($ver)，将重新安装"
        EXISTING_NODE=""
    fi
fi

if [ -z "$EXISTING_NODE" ]; then
    pr "获取最新 LTS 版本..."
    # 优先从 npmmirror 下载（国内更快）
    local NODE_VER
    NODE_VER=$(curl -sL --max-time 10 "https://nodejs.org/dist/index.json" 2>/dev/null \
        | grep -o '"version":"v[0-9][^"]*lts[^"]*"' \
        | head -1 \
        | grep -o 'v[0-9][^"]*' \
        | head -1)
    : "${NODE_VER:=v22.15.1}"
    info "选择版本: $NODE_VER"

    local NODE_TGZ="/tmp/node-${TARGET_ARCH}.tar.xz"
    pr "下载 Node.js ${NODE_VER} for ${TARGET_ARCH}..."

    # 尝试 npmmirror（国内）
    local NODE_URL="https://npmmirror.com/mirrors/node/${NODE_VER}/node-${NODE_VER}-linux-${TARGET_ARCH}.tar.xz"
    pr "来源: npmmirror.com"
    if ! curl -fsSL --connect-timeout 15 -o "$NODE_TGZ" "$NODE_URL" 2>/dev/null; then
        # 回退到 nodejs.org
        NODE_URL="https://nodejs.org/download/release/${NODE_VER}/node-${NODE_VER}-linux-${TARGET_ARCH}.tar.xz"
        pr "回退: nodejs.org"
        curl -fsSL --connect-timeout 15 -o "$NODE_TGZ" "$NODE_URL" || {
            err "Node.js 下载失败，请检查网络"
            rm -f "$NODE_TGZ"
            exit 1
        }
    fi
    log "下载完成"

    # 解压到 /tmp，然后安装到系统路径
    pr "解压到临时目录..."
    local NODE_EXTRACT="/tmp/node-extract-$$"
    mkdir -p "$NODE_EXTRACT"
    tar -xJf "$NODE_TGZ" -C "$NODE_EXTRACT" || {
        err "解压失败"
        rm -f "$NODE_TGZ"; rm -rf "$NODE_EXTRACT"
        exit 1
    }

    # 找到解压出来的目录
    local NODE_SRC=""
    for d in "$NODE_EXTRACT"/node-*; do
        [ -d "$d" ] && [ -x "$d/bin/node" ] && NODE_SRC="$d" && break
    done

    if [ -z "$NODE_SRC" ]; then
        err "解压后找不到 Node.js 目录"
        rm -f "$NODE_TGZ"; rm -rf "$NODE_EXTRACT"
        exit 1
    fi

    # 安装到系统级路径 /usr/local
    pr "安装到 /usr/local（系统级，全局可用）..."
    mkdir -p /usr/local/bin /usr/local/lib /usr/local/share

    cp -a "$NODE_SRC/bin/node" /usr/local/bin/node
    cp -a "$NODE_SRC/bin/npm"  /usr/local/bin/npm
    cp -a "$NODE_SRC/bin/npx"  /usr/local/bin/npx 2>/dev/null || true
    cp -a "$NODE_SRC/lib/"*    /usr/local/lib/
    cp -a "$NODE_SRC/include/"* /usr/local/include/ 2>/dev/null || true
    if [ -d "$NODE_SRC/share/icu" ]; then
        cp -a "$NODE_SRC/share/icu" /usr/local/share/icu
    fi

    chmod +x /usr/local/bin/node
    chmod +x /usr/local/bin/npm
    chmod +x /usr/local/bin/npx 2>/dev/null || true

    rm -f "$NODE_TGZ"
    rm -rf "$NODE_EXTRACT"

    log "Node.js 安装完成: $(/usr/local/bin/node --version)"
    log "npm 安装完成: $(/usr/local/bin/npm --version)"
fi

# 创建 npm wrapper（解决 ICU 路径问题）
NODE_ROOT="$(/usr/local/bin/node -e "var p=require('path');console.log(p.dirname(process.execPath))" 2>/dev/null || echo '/usr/local')"
cat > /usr/local/bin/npm << 'NPMEOF'
#!/bin/sh
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
BASE="$(cd "$(dirname "$SELF")/.." && pwd)"
export NODE_ICU_DATA="${BASE}/share/icu"
export LD_LIBRARY_PATH="${BASE}/lib:$LD_LIBRARY_PATH"
export PATH="${BASE}/bin:$PATH"
exec "${BASE}/bin/node" "${BASE}/lib/node_modules/npm/bin/npm-cli.js" "$@"
NPMEOF
chmod +x /usr/local/bin/npm

# 创建 profile.d 环境变量
mkdir -p /etc/profile.d
cat > /etc/profile.d/node.sh << PROFILEOF
#!/bin/sh
export PATH="/usr/local/bin:\$PATH"
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:\$LD_LIBRARY_PATH"
PROFILEOF
chmod +x /etc/profile.d/node.sh
done_ "Node.js 环境配置"

#===========================================================
# 第四步: 安装 Git + Python3（基础工具）
#===========================================================
step "安装基础工具 (Git + Python3)"

for pkg in git python3; do
    if command -v $pkg >/dev/null 2>&1; then
        info "$pkg 已安装: $($pkg --version 2>/dev/null | head -1)"
    else
        pr "安装 $pkg..."
        opkg update 2>/dev/null && opkg install $pkg 2>/dev/null || {
            warn "$pkg 安装失败，请在 LuCI 中手动安装: opkg install $pkg"
        }
        command -v $pkg >/dev/null 2>&1 && log "$pkg 安装成功" || warn "$pkg 可能未安装成功"
    fi
done
done_ "基础工具"

#===========================================================
# 第五步: 安装 OpenClaw（到 /Configs/openclaw）
#===========================================================
step "安装 OpenClaw（npm 包）"

# 清理旧版残留
if [ -d "/usr/lib/node_modules/openclaw" ] && [ ! -d "/usr/lib/node_modules/openclaw/node_modules" ]; then
    warn "清理旧版损坏的 /usr/lib/node_modules/openclaw"
    rm -rf /usr/lib/node_modules/openclaw
fi

# 设置 npm 全局路径到 /Configs/openclaw
export PATH="/usr/local/bin:$PATH"
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH"

# 检查是否已有
if [ -d "${OPENCLAW_DIR}/node_modules/openclaw" ]; then
    info "检测到已有 OpenClaw，跳过安装"
elif [ -d "/usr/local/lib/node_modules/openclaw" ]; then
    info "使用系统全局 OpenClaw"
else
    pr "安装 OpenClaw npm 包..."
    mkdir -p "$OPENCLAW_DIR"

    # 尝试多个源
    local NPM_OK=0
    for registry in "https://registry.npmmirror.com" "https://registry.npmjs.org"; do
        pr "尝试 npm 镜像: $registry"
        /usr/local/bin/npm install -g openclaw \
            --prefix "$OPENCLAW_DIR" \
            --registry "$registry" \
            2>&1 | tail -3 && NPM_OK=1 && break
    done

    if [ "$NPM_OK" != "1" ]; then
        err "OpenClaw npm 安装失败"
        exit 1
    fi
    log "OpenClaw 安装完成"
fi

# 找到 openclaw.mjs
OPENCLAW_MJS=""
for p in \
    "${OPENCLAW_DIR}/node_modules/openclaw/openclaw.mjs" \
    "${OPENCLAW_DIR}/lib/node_modules/openclaw/openclaw.mjs" \
    "/usr/local/lib/node_modules/openclaw/openclaw.mjs"; do
    [ -f "$p" ] && OPENCLAW_MJS="$p" && break
done

if [ -z "$OPENCLAW_MJS" ]; then
    err "找不到 openclaw.mjs"
    ls "$OPENCLAW_DIR"/node_modules/openclaw/ 2>/dev/null || true
    exit 1
fi
log "OpenClaw 入口: $OPENCLAW_MJS"

# 符号链接到系统全局
mkdir -p /usr/local/lib/node_modules
rm -rf /usr/local/lib/node_modules/openclaw
ln -sf "$(dirname "$OPENCLAW_MJS")" /usr/local/lib/node_modules/openclaw

# 创建 openclaw 命令
cat > /usr/local/bin/openclaw << OCEOF
#!/bin/sh
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:\$LD_LIBRARY_PATH"
export PATH="/usr/local/bin:\$PATH"
exec /usr/local/bin/node "$OPENCLAW_MJS" "\$@"
OCEOF
chmod +x /usr/local/bin/openclaw
ln -sf /usr/local/bin/openclaw /usr/bin/openclaw 2>/dev/null || true

done_ "OpenClaw 安装"

#===========================================================
# 第六步: 下载 ClawPanel Go 二进制
#===========================================================
step "安装 ClawPanel Go 二进制"

# 获取版本
get_latest_pro_version() {
    if [ -n "$CP_VERSION" ] && [ "$CP_VERSION" != "latest" ]; then
        echo "$CP_VERSION"
        return
    fi
    local ver
    ver=$(curl -sL --max-time 10 \
        "https://api.github.com/repos/zhaoxinyi02/ClawPanel/releases" \
        | grep -o '"tag_name"[^,]*' | grep '"tag_name"' | head -1 \
        | cut -d'"' -f4 | grep '^pro-' || true)
    if [ -z "$ver" ]; then
        warn "无法获取最新版本，使用 pro-v5.3.3"
        echo "pro-v5.3.3"
    else
        echo "$ver"
    fi
}

get_download_url() {
    local ver="$1"
    local file_ver
    file_ver=$(echo "$ver" | sed 's/^pro-v/v/;s/^lite-v/v/')
    echo "https://github.com/zhaoxinyi02/ClawPanel/releases/download/${ver}/clawpanel-${file_ver}-linux-${TARGET_ARCH}"
}

CP_VER=$(get_latest_pro_version)
info "版本: $CP_VER"

# 检查是否已有
if [ -x "${CLAWPANEL_DIR}/clawpanel" ]; then
    info "ClawPanel 二进制已存在，跳过下载"
else
    local URL
    URL=$(get_download_url "$CP_VER")
    pr "下载: $URL"
    local TMP="/tmp/clawpanel_binary_$$"
    local HTTP_CODE
    HTTP_CODE=$(curl -sL --fail --connect-timeout 15 --max-time 600 \
        -o "$TMP" -w "%{http_code}" "$URL" 2>/dev/null || echo "000")

    if [ "$HTTP_CODE" != "200" ]; then
        rm -f "$TMP"
        err "下载失败 (HTTP $HTTP_CODE): $URL"
        exit 1
    fi

    if ! is_elf "$TMP"; then
        err "下载的不是有效 ELF 二进制"
        rm -f "$TMP"
        exit 1
    fi

    mv -f "$TMP" "${CLAWPANEL_DIR}/clawpanel"
    chmod +x "${CLAWPANEL_DIR}/clawpanel"
    log "下载完成: $(wc -c < "${CLAWPANEL_DIR}/clawpanel" | awk '{printf "%.1f MB", $1/1024/1024}')"
fi

echo "$CP_VER" > "${CLAWPANEL_DIR}/.version"
log "ClawPanel 版本: $(cat ${CLAWPANEL_DIR}/.version)"
done_ "ClawPanel 二进制"

#===========================================================
# 第七步: 写入配置文件
#===========================================================
step "写入配置文件"

# clawpanel.json
pr "写入 clawpanel.json..."
cat > "${CLAWPANEL_DATA}/clawpanel.json" << CEOF
{
  "port": ${CP_PORT},
  "dataDir": "${CLAWPANEL_DATA}",
  "openClawDir": "${OPENCLAW_DATA}",
  "openClawApp": "$(dirname $OPENCLAW_MJS)",
  "openClawWork": "${OPENCLAW_WORK}",
  "edition": "pro",
  "jwtSecret": "clawpanel-secret-change-me",
  "adminToken": "clawpanel",
  "debug": false
}
CEOF
done_ "clawpanel.json"

# openclaw.json（最小配置）
pr "写入 openclaw.json..."
mkdir -p "${OPENCLAW_DATA}"
if [ ! -f "${OPENCLAW_DATA}/openclaw.json" ]; then
    cat > "${OPENCLAW_DATA}/openclaw.json" << OEOF
{
  "agents": {
    "defaults": {
      "model": {
        "primary": "claude-sonnet-4-6"
      }
    }
  }
}
OEOF
fi
done_ "openclaw.json"

#===========================================================
# 第八步: UCI 配置
#===========================================================
step "写入 UCI 配置"

pr "更新 UCI..."
uci set clawpanel.main='clawpanel' 2>/dev/null || uci add clawpanel main 2>/dev/null || true
uci set clawpanel.main.enabled='1'
uci set clawpanel.main.disk="$CP_BASE_PATH"
uci set clawpanel.main.install_path="$CONFIGS_DIR"
uci set clawpanel.main.port="$CP_PORT"
uci set clawpanel.main.version="$CP_VER"
uci commit clawpanel 2>/dev/null || true
done_ "UCI 配置"

#===========================================================
# 第九步: 启动服务
#===========================================================
step "启动 ClawPanel"

pr "停止旧进程..."
killall -9 clawpanel 2>/dev/null || true
sleep 1

pr "注册开机自启..."
/etc/init.d/clawpanel enable 2>/dev/null || true

pr "启动 ClawPanel..."
export HOME="/root"
export PATH="/usr/local/bin:$PATH"
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH"

setsid /bin/bash -c "
    ${CLAWPANEL_DIR}/clawpanel >> /tmp/clawpanel.log 2>&1 &
" &

# 等待端口
pr "等待服务就绪（端口 $CP_PORT）..."
local i=0
while [ $i -lt 20 ]; do
    if netstat -tulnp 2>/dev/null | grep -q ":${CP_PORT} "; then
        break
    fi
    sleep 1
    i=$((i + 1))
done

echo ""
if netstat -tulnp 2>/dev/null | grep -q ":${CP_PORT} "; then
    log "✅ ClawPanel 启动成功！端口 $CP_PORT"
else
    warn "ClawPanel 可能还在启动，请稍后检查状态"
fi

#===========================================================
# 完成
#===========================================================
echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║           ✅ 安装完成！                          ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
echo "📦 数据目录（外部存储 /Configs，统一管理）:"
echo "   ${CYAN}${CONFIGS_DIR}${NC}"
echo ""
echo "   ├─ clawpanel/           ← ClawPanel 程序"
echo "   ├─ openclaw/           ← OpenClaw npm 包"
echo "   ├─ .openclaw/          ← OpenClaw 工作区"
echo "   └─ .openclaw-work/     ← OpenClaw 运行时"
echo ""
echo "🔧 系统路径（全局可用）:"
echo "   /usr/local/bin/node    → Node.js $(/usr/local/bin/node --version 2>/dev/null)"
echo "   /usr/local/bin/npm     → npm $(/usr/local/bin/npm --version 2>/dev/null)"
echo "   /usr/local/bin/openclaw → OpenClaw CLI"
echo ""
echo "🌐 访问地址:"
echo "   ClawPanel: ${CYAN}http://192.168.1.1:${CP_PORT}/${NC}"
echo ""
echo "🔑 登录令牌: ${YELLOW}clawpanel${NC}"
echo ""
echo "📝 系统重装后恢复:"
echo "   1. 安装 luci-app-clawpanel IPK"
echo "   2. 运行: ${CYAN}CP_BASE_PATH=${CP_BASE_PATH} sh install.sh${NC}"
echo ""
