#!/bin/sh
# clawpanel-env - auto install ClawPanel from GitHub releases
# Env vars:
#   CP_BASE_PATH      installation base path
#   CP_VERSION       optional fixed version like pro-v5.3.3; empty/latest = detect
#   CP_OPENCLAW_DIR optional OpenClaw data dir; if empty, auto-derived

set -e

CP_BASE_PATH="${CP_BASE_PATH:-}"
CP_VERSION="${CP_VERSION:-latest}"
CP_OPENCLAW_DIR="${CP_OPENCLAW_DIR:-}"

[ "$(id -u)" = "0" ] || { echo "Error: must run as root"; exit 1; }
[ -n "$CP_BASE_PATH" ] || { echo "Error: CP_BASE_PATH not set"; exit 1; }

# 閳光偓閳光偓 Timeout wrapper ( BusyBox-compatible ) 閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓閳光偓
# Usage: timeout_wrapper <seconds> <command>...
_timeout_cmd() {
    local secs="$1"; shift
    timeout -t "$secs" "$@" 2>/dev/null && return 0
    return 1
}

get_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64) echo "amd64" ;;
        armv7l|armv7) echo "armv7" ;;
        armv6l|armv6) echo "armv6" ;;
        i386|i686) echo "amd64" ;;
        *) echo "" ;;
    esac
}

CP_ARCH="$(get_arch)"
[ -n "$CP_ARCH" ] || { echo "Error: unsupported arch: $(uname -m)"; exit 1; }

check_disk() {
    local path="$1"
    local needed_mb="${2:-100}"
    if [ -d "$path" ]; then
        local avail_mb
        avail_mb=$(df -m "$path" 2>/dev/null | tail -1 | awk '{print $4}')
        if [ -n "$avail_mb" ] && [ "$avail_mb" -lt "$needed_mb" ]; then
            echo "Error: not enough disk space. Available ${avail_mb}MB, need ${needed_mb}MB"
            return 1
        fi
    fi
}

is_elf() {
    [ -f "$1" ] || return 1
    local first4=""
    first4=$(od -An -tx1 -N4 "$1" 2>/dev/null | tr -d ' \n\r')
    [ -n "$first4" ] || first4=$(od -A n -t x1 -N 4 "$1" 2>/dev/null | tr -d ' \n\r')
    [ "$first4" = "7f454c46" ] && return 0
    # Fallback: large file is likely a real binary
    local fsize
    fsize=$(wc -c < "$1" 2>/dev/null || echo 0)
    [ -n "$fsize" ] && [ "$fsize" -gt 20000000 ]
}

get_latest_pro_version() {
    if [ -n "$CP_VERSION" ] && [ "$CP_VERSION" != "latest" ]; then
        printf '%s' "$CP_VERSION"
        return
    fi
    local ver
    ver=$(curl -sL --max-time 10 \
        "https://api.github.com/repos/zhaoxinyi02/ClawPanel/releases" 2>/dev/null \
        | grep '"tag_name"' | cut -d'"' -f4 | grep '^pro-' | head -1 || true)
    if [ -z "$ver" ]; then
        printf '%s' "pro-v5.3.3"
    else
        printf '%s' "$ver"
    fi
}

get_download_url() {
    local ver="$1"
    local arch="$2"
    local file_ver
    file_ver=$(echo "$ver" | sed 's/^pro-v/v/;s/^lite-v/v/')
    printf '%s' "https://github.com/zhaoxinyi02/ClawPanel/releases/download/${ver}/clawpanel-${file_ver}-linux-${arch}"
}

download_binary() {
    local url="$1"
    local dest="$2"
    local tmpfile="/tmp/clawpanel_download_$$"
    echo "Downloading from: $url"

    local http_code
    http_code=$(curl -sL --fail --connect-timeout 15 --max-time 1800 \
        -o "$tmpfile" -w "%{http_code}" "$url" 2>/dev/null || true)
    if [ "$http_code" != "200" ]; then
        rm -f "$tmpfile"
        echo "Error: download failed (HTTP ${http_code:-unknown})"
        return 1
    fi

    local fsize
    fsize=$(wc -c < "$tmpfile" 2>/dev/null || echo 0)
    if [ -z "$fsize" ] || [ "$fsize" -lt 5000000 ]; then
        rm -f "$tmpfile"
        echo "Error: downloaded file too small (${fsize} bytes)"
        return 1
    fi

    if ! is_elf "$tmpfile"; then
        local bad_size
        bad_size=$(wc -c < "$tmpfile" 2>/dev/null || echo 0)
        echo "Error: downloaded file is not a valid ELF binary (size: ${bad_size} bytes)"
        return 1
    fi

    mv -f "$tmpfile" "$dest"
    chmod +x "$dest"
    echo "Downloaded: $(echo "$fsize" | awk '{printf "%.1f MB", $1/1024/1024}') 閳?$dest"
}

do_setup() {
    local cp_install_path="${CP_BASE_PATH}/clawpanel"
    local cp_data="${cp_install_path}/data"
    local cp_binary="${cp_install_path}/clawpanel"
    local cp_port="${CP_PORT:-19527}"
    # OpenClaw 閻╊喖缍嶉敍姘洤閺嬫粎骞嗘晶鍐ㄥ綁闁插繑婀拋鍓х枂閿涘矁鍤滈崝銊﹀腹鐎甸棿璐?<install_path>/clawpanel/data
    local openclaw_dir="${CP_OPENCLAW_DIR:-${CP_BASE_PATH}/.openclaw}"
    local openclaw_app="${CP_BASE_PATH}/clawpanel/app"
    local openclaw_work="${CP_BASE_PATH}/clawpanel/work"

    echo "=== ClawPanel Setup ==="
    echo "Install path: $cp_install_path"
    echo "Data path: $cp_data"
    echo "OpenClaw dir: $openclaw_dir"
    echo "App dir: $openclaw_app"
    echo "Work dir: $openclaw_work"
    echo "Port: $cp_port"
    echo "Architecture: $CP_ARCH"

    check_disk "$CP_BASE_PATH" 100 || exit 1
    mkdir -p "$CP_BASE_PATH" "$cp_install_path" "$cp_data" "${CP_BASE_PATH}/.openclaw" "$openclaw_app" "$openclaw_work"

    echo "Detecting latest pro version..."
    local version
    version=$(get_latest_pro_version)
    echo "Using version: $version"

    local url
    url=$(get_download_url "$version" "$CP_ARCH")
    download_binary "$url" "$cp_binary" || exit 1

    # 閻╁瓨甯存担璺ㄦ暏 GitHub API 閻楀牊婀伴崣鍑ょ礄娑撳秶鏁?binary --version閿涘矂浼╅崗宥堜粓缂冩垼绉撮弮璺哄幢娴ｅ骏绱?    local actual_ver="$version"
    echo "$actual_ver" > "${cp_install_path}/.version"
    echo "Version: $actual_ver"

    # 娣囨繂鐡ㄩ崚?UCI閿涘牅绶?init.d 閸氬海鐢婚崥顖氬З娴ｈ法鏁ら敍?    uci set clawpanel.main.enabled='1'
    uci set clawpanel.main.install_path="$CP_BASE_PATH"
    uci set clawpanel.main.openclaw_dir="$openclaw_dir"
    uci set clawpanel.main.port="$cp_port"
    uci set clawpanel.main.version="$actual_ver"
    uci commit clawpanel

    # 閸愭瑥鍙?clawpanel.json閿涘牏鏁?init 閼存碍婀?start_service 閸愬秵顐肩憰鍡欐磰閿涘矁绻栭柌灞藉帥閸愭瑤绔村▎鈥茬箽閹躲倧绱?    cat > "${cp_data}/clawpanel.json" <<EOF
{
  "port": ${cp_port},
  "dataDir": "${cp_data}",
  "openClawDir": "${openclaw_dir}",
  "openClawApp": "${openclaw_app}",
  "openClawWork": "${openclaw_work}",
  "edition": "pro",
  "jwtSecret": "clawpanel-secret-change-me",
  "adminToken": "clawpanel",
  "debug": false
}
EOF
    echo "Config written: ${cp_data}/clawpanel.json"

    # 閸氼垰濮?ClawPanel閿涘潟nit 閼存碍婀版导姘冲殰閸斻劌鍟€濞嗏€冲晸閸忋儲顒滅涵顔炬畱 clawpanel.json閿?    echo "Starting ClawPanel..."
    /etc/init.d/clawpanel enable 2>/dev/null || true
    _timeout_cmd 10 /etc/init.d/clawpanel start || true

    echo ""
    echo "=== Installation Complete ==="
    echo "Binary: $cp_binary"
    echo "Config: ${cp_data}/clawpanel.json"
    echo "OpenClaw dir: $openclaw_dir"
    echo ""
    echo "Hint: if service is not running yet, wait 10s then run:"
    echo "  /etc/init.d/clawpanel status"
}

case "${1:-setup}" in
    setup) do_setup ;;
    *) echo "Usage: $0 [setup]"; exit 1 ;;
esac