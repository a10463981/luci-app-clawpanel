#!/bin/sh
#===========================================================
#  clawpanel-env — ClawPanel 安装脚本 v3
#  统一目录: /Configs/clawpanel /Configs/openclaw /Configs/.openclaw
#  Node.js: 系统级安装到 /usr/local/bin/
#===========================================================
# ⚠️ 注意: 此文件用 sh (dash) 运行，不用 bash
# ⚠️ 所有函数定义在全局，不用嵌套函数

# 颜色（ASCII 安全，不依赖 ANSI 序列特性）
RED='[✗]'; GREEN='[✓]'; YELLOW='[!]'; BLUE='[ℹ]'; CYAN='═══'; NC=''

log()   { echo "$GREEN $1"; }
info()  { echo "$BLUE $1"; }
warn()  { echo "$YELLOW $1"; }
err()   { echo "$RED $1" >&2; }
step()  { echo ""; echo "$CYAN $1 ═══"; }
done_() { echo "$GREEN $1 完成"; }
pr()    { echo "$BLUE ▸ $1"; }

#===========================================================
# 全局变量
#===========================================================
ARCH="$(uname -m)"
# x86_64: 官方 Node.js (glibc)；aarch64/arm64: 用户 GitHub (musl)
case "$ARCH" in
    x86_64)
        TARGET_ARCH_NODE="x64"
        NODE_INSTALL_SOURCE="official"
        TARGET_ARCH_CP="amd64"
        ;;
    aarch64|arm64)
        TARGET_ARCH_NODE="arm64"
        NODE_INSTALL_SOURCE="github"
        TARGET_ARCH_CP="arm64"
        ;;
    *)
        err "不支持架构: $ARCH（仅支持 x86_64 和 aarch64/arm64）"
        exit 1
        ;;
esac

CP_BASE_PATH="${CP_BASE_PATH:-}"
CP_VERSION="${CP_VERSION:-latest}"
CONFIGS_DIR=""
CLAWPANEL_DIR=""
CLAWPANEL_DATA=""
OPENCLAW_DIR=""
OPENCLAW_DATA=""
OPENCLAW_WORK=""
CP_PORT="19527"

#===========================================================
# 工具函数（全局）
#===========================================================
# 检查磁盘空间
check_disk() {
    local path="$1"
    local need_mb="${2:-500}"
    if [ ! -d "$path" ]; then
        err "路径不存在: $path"
        return 1
    fi
    local avail_mb
    avail_mb=$(df -m "$path" 2>/dev/null | tail -1 | awk '{print $4}')
    avail_mb=${avail_mb:-0}
    if [ "$avail_mb" -lt "$need_mb" ]; then
        err "磁盘空间不足: 可用 ${avail_mb}MB，需要 ${need_mb}MB"
        return 1
    fi
    log "磁盘空间: ${avail_mb}MB 可用"
    return 0
}

# 检查文件是否为 ELF
is_elf() {
    [ -f "$1" ] || return 1
    # 用 head 读 4 字节，避免 od/wc 工具不存在时报错
    local magic
    magic=$(head -c 4 "$1" 2>/dev/null | od -An -tx1 | tr -d ' \n')
    [ "$magic" = "7f454c46" ] && return 0
    # Fallback: 文件大于 20MB
    local sz
    sz=$(wc -c < "$1" 2>/dev/null || echo 0)
    [ -n "$sz" ] && [ "$sz" -gt 20000000 ]
}

# 检测已安装的 Node.js
_detect_node() {
    local np
    np=$(command -v node 2>/dev/null)
    [ -n "$np" ] && [ -x "$np" ] && echo "$np" && return 0
    [ -x "/usr/local/bin/node" ] && echo "/usr/local/bin/node" && return 0
    [ -x "/opt/node23/bin/node" ] && echo "/opt/node23/bin/node" && return 0
    [ -x "/usr/bin/node" ] && echo "/usr/bin/node" && return 0
    [ -x "/opt/node23/bin/node" ] && echo "/opt/node23/bin/node" && return 0
    return 1
}

# 获取 ClawPanel 最新 pro 版本
get_latest_pro_version() {
    if [ -n "$CP_VERSION" ] && [ "$CP_VERSION" != "latest" ]; then
        echo "$CP_VERSION"
        return
    fi
    local ver
    ver=$(curl -sL  \
        "https://api.github.com/repos/zhaoxinyi02/ClawPanel/releases" \
        | grep -o '"tag_name"[^,]*' | grep '"tag_name"' | head -1 \
        | cut -d'"' -f4 | grep '^pro-' | head -1 || true)
    if [ -z "$ver" ]; then
        warn "无法获取最新版本，使用 pro-v5.3.3"
        echo "pro-v5.3.3"
    else
        echo "$ver"
    fi
}

#===========================================================
# 安装逻辑（setup 子命令）
#===========================================================
cmd_setup() {
    step "第一步: 检查环境"

    [ "$(id -u)" = "0" ] || { err "必须以 root 用户运行"; exit 1; }
    info "架构: $ARCH -> Node.js: $TARGET_ARCH_NODE, ClawPanel: $TARGET_ARCH_CP"
    info "时间: $(date '+%Y-%m-%d %H:%M:%S')"

    # 检查 CP_BASE_PATH
    if [ -z "$CP_BASE_PATH" ]; then
        err "CP_BASE_PATH 未设置（请从 LuCI 安装向导调用）"
        exit 1
    fi
    CP_BASE_PATH="${CP_BASE_PATH%/}"  # 去掉末尾斜杠

    # 禁止系统路径
    case "$CP_BASE_PATH" in
        /|/overlay|/rom|/boot|/proc|/sys|/dev|/opt|/tmp|/var|/etc|/root|/usr)
            err "禁止使用系统路径: $CP_BASE_PATH"
            exit 1 ;;
    esac

    # 初始化路径
    CONFIGS_DIR="${CP_BASE_PATH}/Configs"
    CLAWPANEL_DIR="${CONFIGS_DIR}/clawpanel"
    CLAWPANEL_DATA="${CLAWPANEL_DIR}/data"
    OPENCLAW_DIR="${CONFIGS_DIR}/openclaw"
    OPENCLAW_DATA="${CONFIGS_DIR}/.openclaw"
    OPENCLAW_WORK="${CONFIGS_DIR}/.openclaw-work"

    # 检查磁盘
    check_disk "$CP_BASE_PATH" 500 || exit 1

    #===========================================================
    step "第二步: 创建目录结构"
    #===========================================================
    pr "创建 /Configs 目录..."
    mkdir -p "$CONFIGS_DIR" "$CLAWPANEL_DIR" "$CLAWPANEL_DATA"
    mkdir -p "$OPENCLAW_DIR" "$OPENCLAW_DATA" "$OPENCLAW_WORK"
    done_ "目录结构"
    echo "  ${CONFIGS_DIR}/"
    echo "  ├── clawpanel/          <- ClawPanel 程序"
    echo "  │    ├── data/         <- 配置 + 数据"
    echo "  │    └── clawpanel     <- Go 二进制"
    echo "  ├── openclaw/          <- OpenClaw npm 包"
    echo "  ├── .openclaw/         <- OpenClaw 工作区"
    echo "  └── .openclaw-work/    <- 运行时目录"

    #===========================================================
    step "第三步: 安装 Node.js（系统级）"
    #===========================================================
    # 检测已有 Node.js
    existing_node=$(_detect_node) || true

    # npm wrapper: 使用 /usr/bin/npm（来自 musl Node.js 包）
    mkdir -p /usr/local/bin
    cat > /usr/local/bin/npm << NPMEOF
#!/bin/sh
SELF_DIR="/usr/bin"
export NODE_ICU_DATA="/usr/share/icu"
exec "${SELF_DIR}/node" "${SELF_DIR}/../lib/node_modules/npm/bin/npm-cli.js" "$@"
NPMEOF
    chmod +x /usr/local/bin/npm
    cat > /usr/local/bin/npx << NPXEOF
#!/bin/sh
SELF_DIR="/usr/bin"
export NODE_ICU_DATA="/usr/share/icu"
exec "${SELF_DIR}/node" "${SELF_DIR}/../lib/node_modules/npm/bin/npx-cli.js" "$@"
NPXEOF
    chmod +x /usr/local/bin/npx
    ln -sf /usr/bin/node /usr/local/bin/node 2>/dev/null || true
    log "npm wrapper 已创建 ✓"


    if [ -z "$existing_node" ]; then
        # ClawPanel 要求 Node.js v22+，强制使用 v22 LTS
        local NODE_VER="v22.22.2"
        info "强制版本: $NODE_VER (ClawPanel 最低要求 v22)"

        local NODE_TGZ="/tmp/node-${TARGET_ARCH_NODE}.tar.xz"
        pr "下载 Node.js ${NODE_VER} for ${TARGET_ARCH_NODE}..."

        # x86_64: 官网 / npmmirror；aarch64/arm64: 用户 GitHub
        if [ "$NODE_INSTALL_SOURCE" = "official" ]; then
            pr "来源: npmmirror.com (官方 x64)"
            local NODE_URL="https://npmmirror.com/mirrors/node/${NODE_VER}/node-${NODE_VER}-linux-${TARGET_ARCH_NODE}.tar.xz"
            if ! curl -fsSL --connect-timeout 120 -o "$NODE_TGZ" "$NODE_URL" 2>/dev/null; then
                pr "回退: nodejs.org"
                NODE_URL="https://nodejs.org/download/release/${NODE_VER}/node-${NODE_VER}-linux-${TARGET_ARCH_NODE}.tar.xz"
                curl -fsSL --connect-timeout 120 -o "$NODE_TGZ" "$NODE_URL" || {
                    err "Node.js 下载失败"
                    rm -f "$NODE_TGZ"
                    exit 1
                }
            fi
        else
            pr "来源: a10463981/node-openwrt-arm64 (musl 专用)"
            local NODE_URL="https://github.com/a10463981/node-openwrt-arm64/releases/download/v${NODE_VER#v}/node-${NODE_VER}-openwrt-arm64-fixed.tar.gz"
            curl -fsSL --connect-timeout 120 -o "$NODE_TGZ" "$NODE_URL" || {
                err "Node.js 下载失败"
                rm -f "$NODE_TGZ"
                exit 1
            }
        fi
        log "下载完成"

        # 解压到 /tmp，然后复制到 /usr/local
        pr "解压到临时目录..."
        local NODE_EXTRACT="/tmp/node-extract-$$"
        mkdir -p "$NODE_EXTRACT"
        tar -xJf "$NODE_TGZ" -C "$NODE_EXTRACT" || {
            err "解压失败"
            rm -f "$NODE_TGZ"; rm -rf "$NODE_EXTRACT"
            exit 1
        }

        # 找到解压出来的目录
        local NODE_SRC=""
        for d in "$NODE_EXTRACT"/node-*; do
            [ -d "$d" ] && [ -x "$d/bin/node" ] && NODE_SRC="$d" && break
        done

        if [ -z "$NODE_SRC" ]; then
            err "解压后找不到 Node.js 目录"
            rm -f "$NODE_TGZ"; rm -rf "$NODE_EXTRACT"
            exit 1
        fi

        # 安装到系统级路径
        pr "安装到 /usr/local（系统级，全局可用）..."
        mkdir -p /usr/local/bin /usr/local/lib /usr/local/share
        cp -a "$NODE_SRC/bin/node" /usr/local/bin/node
        cp -a "$NODE_SRC/bin/npm"  /usr/local/bin/npm
        cp -a "$NODE_SRC/bin/npx"  /usr/local/bin/npx 2>/dev/null || true
        cp -a "$NODE_SRC/lib/"*    /usr/local/lib/ 2>/dev/null || true
        if [ -d "$NODE_SRC/share/icu" ]; then
            cp -a "$NODE_SRC/share/icu" /usr/local/share/ 2>/dev/null || true
        fi
        chmod +x /usr/local/bin/node
        chmod +x /usr/local/bin/npm
        chmod +x /usr/local/bin/npx 2>/dev/null || true

        rm -f "$NODE_TGZ"
        rm -rf "$NODE_EXTRACT"

        log "Node.js 安装完成: $(/usr/local/bin/node --version 2>/dev/null)"
        log "npm 安装完成: $(/usr/local/bin/npm --version 2>/dev/null)"
    fi

    # npm wrapper（解决 ICU 路径）
    pr "配置 npm wrapper..."
    cat > /usr/local/bin/npm << 'NPMEOF'
#!/bin/sh
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
BASE="$(cd "$(dirname "$SELF")/.." && pwd)"
export NODE_ICU_DATA="${BASE}/share/icu"
export LD_LIBRARY_PATH="${BASE}/lib:$LD_LIBRARY_PATH"
export PATH="${BASE}/bin:$PATH"
exec "${BASE}/bin/node" "${BASE}/lib/node_modules/npm/bin/npm-cli.js" "$@"
NPMEOF
    chmod +x /usr/local/bin/npm

    # profile.d 环境变量
    mkdir -p /etc/profile.d
    cat > /etc/profile.d/node.sh << 'PROFILEOF'
#!/bin/sh
export PATH="/usr/local/bin:$PATH"
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH"
PROFILEOF
    chmod +x /etc/profile.d/node.sh
    done_ "Node.js 环境配置"

    #===========================================================
    step "第四步: 安装基础工具 (Git + Python3)"
    #===========================================================
    for pkg in git python3; do
        if command -v $pkg >/dev/null 2>&1; then
            info "$pkg 已安装: $($pkg --version 2>/dev/null | head -1)"
        else
            pr "安装 $pkg..."
            opkg update 2>/dev/null && opkg install $pkg 2>/dev/null || {
                warn "$pkg 安装失败，请在 LuCI 中手动安装: opkg install $pkg"
            }
            command -v $pkg >/dev/null 2>&1 && log "$pkg 安装成功" || warn "$pkg 可能未安装成功"
        fi
    done
    done_ "基础工具"

    #===========================================================
    step "第五步: 安装 OpenClaw（npm 包）"
    #===========================================================
    export PATH="/usr/local/bin:$PATH"
    export NODE_ICU_DATA="/usr/local/share/icu"
    export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH"

    if [ -d "${OPENCLAW_DIR}/node_modules/openclaw" ]; then
        info "检测到已有 OpenClaw，跳过安装"
    elif [ -d "/usr/local/lib/node_modules/openclaw" ]; then
        info "使用系统全局 OpenClaw"
    else
        pr "安装 OpenClaw npm 包..."
        mkdir -p "$OPENCLAW_DIR"

        local NPM_OK=0
        for registry in "https://registry.npmmirror.com" "https://registry.npmjs.org"; do
            pr "尝试 npm 镜像: $registry"
            /usr/local/bin/npm install -g openclaw \
                --prefix "$OPENCLAW_DIR" \
                --registry "$registry" \
                2>&1 | tail -3 && NPM_OK=1 && break
        done

        if [ "$NPM_OK" != "1" ]; then
            err "OpenClaw npm 安装失败"
            exit 1
        fi
        log "OpenClaw 安装完成"
    # Patch Unicode property escapes for this Node.js V8 build
    # (\p{Extended_Pictographic} not supported in some V8 builds)
    OPENCLAW_DIST="$(dirname "$OPENCLAW_MJS")/dist"
    if [ -d "$OPENCLAW_DIST" ]; then
        pr "Patch OpenClaw Unicode regex (V8 compatibility)..."
        sed -i "s/\\p{Extended_Pictographic}/\\x{1F300}-\\x{1FAFF}/g" "$OPENCLAW_DIST"/ansi-*.js 2>/dev/null || true
        sed -i "s/\\p{Regional_Indicator}//g" "$OPENCLAW_DIST"/ansi-*.js 2>/dev/null || true
        sed -i "s/\\p{Extended_Pictographic}/\\x{1F300}-\\x{1FAFF}/g" "$OPENCLAW_DIST"/monitor-*.js 2>/dev/null || true
        sed -i "s/\\p{Emoji_Modifier}/\\x{1F3FB}-\\x{1F3FF}/g" "$OPENCLAW_DIST"/monitor-*.js 2>/dev/null || true
        sed -i "s/\\p{Emoji_Presentation}|\\p{Extended_Pictographic}/[\\x{1F000}-\\x{1FFFF}]/g" "$OPENCLAW_DIST"/pi-embedded-helpers-*.js 2>/dev/null || true
        log "OpenClaw 兼容性修复完成"
    fi

    fi

    # 找到 openclaw.mjs
    local OPENCLAW_MJS=""
    for p in \
        "${OPENCLAW_DIR}/node_modules/openclaw/openclaw.mjs" \
        "${OPENCLAW_DIR}/lib/node_modules/openclaw/openclaw.mjs" \
        "/usr/local/lib/node_modules/openclaw/openclaw.mjs"; do
        [ -f "$p" ] && OPENCLAW_MJS="$p" && break
    done

    if [ -z "$OPENCLAW_MJS" ]; then
        err "找不到 openclaw.mjs"
        ls "$OPENCLAW_DIR"/node_modules/openclaw/ 2>/dev/null || true
        exit 1
    fi
    log "OpenClaw 入口: $OPENCLAW_MJS"

    # 符号链接
    mkdir -p /usr/local/lib/node_modules
    rm -rf /usr/local/lib/node_modules/openclaw
    ln -sf "$(dirname "$OPENCLAW_MJS")" /usr/local/lib/node_modules/openclaw

    # openclaw 命令
    cat > /usr/local/bin/openclaw << OCEOF
#!/bin/sh
export NODE_ICU_DATA="/usr/local/share/icu"
export LD_LIBRARY_PATH="/usr/local/lib:\$LD_LIBRARY_PATH"
export PATH="/usr/local/bin:\$PATH"
exec /usr/local/bin/node "$OPENCLAW_MJS" "\$@"
OCEOF
    chmod +x /usr/local/bin/openclaw
    ln -sf /usr/local/bin/openclaw /usr/bin/openclaw 2>/dev/null || true
    done_ "OpenClaw 安装"

    #===========================================================
    step "第六步: 下载 ClawPanel Go 二进制"
    #===========================================================
    local CP_VER
    CP_VER=$(get_latest_pro_version)
    info "版本: $CP_VER"

    if [ -x "${CLAWPANEL_DIR}/clawpanel" ]; then
        info "ClawPanel 二进制已存在，跳过下载"
    else
        local FILE_VER
        FILE_VER=$(echo "$CP_VER" | sed 's/^pro-v/v/;s/^lite-v/v/')
        local URL="https://github.com/zhaoxinyi02/ClawPanel/releases/download/${CP_VER}/clawpanel-${FILE_VER}-linux-arm64"
        pr "下载: $URL"
        local TMP="/tmp/clawpanel_binary_$$"
        local HTTP_CODE
        HTTP_CODE=$(curl -sL --fail --connect-timeout 15  \
            -o "$TMP" -w "%{http_code}" "$URL" 2>/dev/null || echo "000")

        if [ "$HTTP_CODE" != "200" ]; then
            rm -f "$TMP"
            err "下载失败 (HTTP $HTTP_CODE): $URL"
            exit 1
        fi

        if ! is_elf "$TMP"; then
            err "下载的不是有效 ELF 二进制"
            rm -f "$TMP"
            exit 1
        fi

        mv -f "$TMP" "${CLAWPANEL_DIR}/clawpanel"
        chmod +x "${CLAWPANEL_DIR}/clawpanel"
        log "下载完成: $(wc -c < "${CLAWPANEL_DIR}/clawpanel" | awk '{printf "%.1f MB", $1/1024/1024}')"
    fi

    echo "$CP_VER" > "${CLAWPANEL_DIR}/.version"
    log "ClawPanel 版本: $(cat ${CLAWPANEL_DIR}/.version)"
    done_ "ClawPanel 二进制"

    #===========================================================
    step "第七步: 写入配置文件"
    #===========================================================
    pr "写入 clawpanel.json..."
    mkdir -p "$CLAWPANEL_DATA"
    cat > "${CLAWPANEL_DATA}/clawpanel.json" << CEOF
{
  "port": ${CP_PORT},
  "dataDir": "${CLAWPANEL_DATA}",
  "openClawDir": "${OPENCLAW_DATA}",
  "openClawApp": "$(dirname $OPENCLAW_MJS)",
  "openClawWork": "${OPENCLAW_WORK}",
  "edition": "pro",
  "jwtSecret": "clawpanel-secret-change-me",
  "adminToken": "clawpanel",
  "debug": false
}
CEOF
    done_ "clawpanel.json"

    pr "写入 openclaw.json..."
    mkdir -p "$OPENCLAW_DATA"
    if [ ! -f "${OPENCLAW_DATA}/openclaw.json" ]; then
        cat > "${OPENCLAW_DATA}/openclaw.json" << 'OEOF'
{
  "agents": { "defaults": { "model": { "primary": "claude-sonnet-4-6" } } }
}
OEOF
    fi
    done_ "openclaw.json"

    #===========================================================
    step "第八步: UCI 配置"
    #===========================================================
    pr "更新 UCI..."
    uci set clawpanel.main='clawpanel' 2>/dev/null || uci add clawpanel main 2>/dev/null || true
    uci set clawpanel.main.enabled='1'
    uci set clawpanel.main.disk="$CP_BASE_PATH"
    uci set clawpanel.main.install_path="$CONFIGS_DIR"
    uci set clawpanel.main.port="$CP_PORT"
    uci set clawpanel.main.version="$CP_VER"
    uci commit clawpanel 2>/dev/null || true
    done_ "UCI 配置"

    #===========================================================
    step "第九步: 启动服务"
    #===========================================================
    pr "停止旧进程..."
    killall -9 clawpanel 2>/dev/null || true
    sleep 1

    pr "注册开机自启..."
    /etc/init.d/clawpanel enable 2>/dev/null || true

    pr "启动 ClawPanel..."
    export HOME="/root"
    export PATH="/usr/local/bin:$PATH"
    export NODE_ICU_DATA="/usr/local/share/icu"
    export LD_LIBRARY_PATH="/usr/local/lib:$LD_LIBRARY_PATH"

    setsid /bin/bash -c "
        ${CLAWPANEL_DIR}/clawpanel >> /tmp/clawpanel.log 2>&1 &
    " &

    pr "等待服务就绪（端口 $CP_PORT）..."
    local i=0
    while [ $i -lt 20 ]; do
        if netstat -tulnp 2>/dev/null | grep -q ":${CP_PORT} "; then
            break
        fi
        sleep 1
        i=$((i + 1))
    done

    echo ""
    if netstat -tulnp 2>/dev/null | grep -q ":${CP_PORT} "; then
        log "ClawPanel 启动成功！端口 $CP_PORT"
    else
        warn "ClawPanel 可能还在启动，请稍后检查状态"
    fi

    #===========================================================
    step "完成"
    #===========================================================
    echo ""
    echo "╔══════════════════════════════════════════════════╗"
    echo "║           安装完成！                           ║"
    echo "╚══════════════════════════════════════════════════╝"
    echo ""
    echo "数据目录: ${CONFIGS_DIR}"
    echo "  ├── clawpanel/        <- ClawPanel 程序"
    echo "  ├── openclaw/        <- OpenClaw npm 包"
    echo "  ├── .openclaw/       <- 工作区"
    echo "  └── .openclaw-work/   <- 运行时"
    echo ""
    echo "访问地址: http://192.168.1.1:${CP_PORT}/"
    echo "令牌: clawpanel"
    echo ""
}

#===========================================================
# 主入口
#===========================================================
CMD="${1:-}"
if [ "$CMD" = "setup" ]; then
    cmd_setup
else
    echo "用法: $0 setup"
    echo "请通过 LuCI 界面调用"
fi
