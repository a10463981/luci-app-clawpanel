#!/bin/sh
# clawpanel-env - ClawPanel installation script
# Env vars:
#   CP_BASE_PATH      - installation base path (e.g. /mnt/sda1)
#   CP_VERSION        - version to install (e.g. pro-v5.3.3)
#   CP_OPENCLAW_DIR   - OpenClaw data directory (e.g. /mnt/sda1/clawpanel/data/.openclaw)

set -e

CP_BASE_PATH="${CP_BASE_PATH:-/mnt/sda1}"
CP_VERSION="${CP_VERSION:-latest}"
CP_OPENCLAW_DIR="${CP_OPENCLAW_DIR:-}"

# Check if running as root
if [ "$(id -u)" != "0" ]; then
    echo "Error: This script must be run as root"
    exit 1
fi

# Detect system
detect_system() {
    if [ -f /etc/openwrt_release ]; then
        echo "openwrt"
    elif [ -f /etc/debian_version ]; then
        echo "debian"
    elif [ -f /etc/arch-release ]; then
        echo "arch"
    else
        echo "unknown"
    fi
}

# Get OS type
OS_TYPE=$(detect_system)

# Detect architecture
get_arch() {
    local arch=$(uname -m)
    case $arch in
        aarch64) echo "arm64" ;;
        armv7l)  echo "armv7" ;;
        armv6l)  echo "armv6" ;;
        x86_64)  echo "amd64" ;;
        i386|i686) echo "amd64" ;;
        *) echo "" ;;
    esac
}

CP_ARCH=$(get_arch)
[ -z "$CP_ARCH" ] && { echo "Unsupported architecture: $(uname -m)"; exit 1; }

# Detect download source - use Chinese mirror proxy for speed
get_download_url() {
    local ver="$1"
    local arch="$2"
    # Version tag "pro-v5.3.3" → asset filename "clawpanel-v5.3.3-linux-arm64"
    local ver_stripped=$(echo "$ver" | sed 's/^pro-v/v/;s/^lite-v/v/;s/^v\([0-9]\)/v\1/')
    local raw_url="https://github.com/zhaoxinyi02/ClawPanel/releases/download/${ver}/clawpanel-${ver_stripped}-linux-${arch}"
    # Use ghproxy.com for China speedup, fallback to raw GitHub
    echo "https://ghproxy.com/${raw_url}"
}

# Check disk space
check_disk() {
    local path="$1"
    local needed_mb="${2:-100}"

    if [ -d "$path" ]; then
        local avail_mb=$(df -m "$path" | tail -1 | awk '{print $4}')
        if [ "$avail_mb" -lt "$needed_mb" ]; then
            echo "Error: Not enough disk space. Available: ${avail_mb}MB, needed: ${needed_mb}MB"
            return 1
        fi
    fi
}

# Create directories
create_dirs() {
    local base="$1"
    local data_dir="${2:-${base}/clawpanel/data}"
    local openclaw_dir="${3:-${data_dir}/.openclaw}"

    mkdir -p "$base"
    mkdir -p "$data_dir"
    mkdir -p "$openclaw_dir"

    echo "Directories created:"
    echo "  - $base"
    echo "  - ${data_dir}"
    echo "  - ${openclaw_dir}"
}

# Download ClawPanel binary
download_binary() {
    local url="$1"
    local dest="$2"

    echo "Downloading from: $url"

    local tmpfile="/tmp/clawpanel_bin_$$"
    # Download silently (-s), follow redirects (-L), capture HTTP code (-w)
    local http_code
    http_code=$(curl -sL -o "$tmpfile" -w "%{http_code}" "$url")

    if [ "$http_code" != "200" ]; then
        rm -f "$tmpfile"
        echo "Error: Download failed (HTTP $http_code)"
        return 1
    fi

    # Check file size: arm64 binary should be ~28MB
    local fsize
    fsize=$(wc -c < "$tmpfile" 2>/dev/null || echo "0")
    if [ -z "$fsize" ] || [ "$fsize" -lt 1000000 ]; then
        rm -f "$tmpfile"
        echo "Error: Downloaded file too small (${fsize} bytes), not a valid binary"
        return 1
    fi

    # Verify ELF magic bytes: first 4 bytes must be 0x7F 'E' 'L' 'F'
    local first4
    first4=$(od -A n -t x1 -N 4 "$tmpfile" 2>/dev/null)
    first4=$(echo "$first4" | tr -d ' \n\r')
    if [ "$first4" != "7f454c46" ]; then
        rm -f "$tmpfile"
        echo "Error: File is not a valid ELF binary (magic: $first4)"
        return 1
    fi

    mv -f "$tmpfile" "$dest"
    chmod +x "$dest"
    echo "Binary downloaded: $(echo "$fsize" | awk '{printf "%.1f MB", $1/1024/1024}') → $dest"
    return 0
}

# Setup uci config
setup_uci() {
    local install_path="$1"
    local port="${2:-19527}"
    local version="$3"

    uci set clawpanel.main.enabled='1'
    uci set clawpanel.main.install_path="$install_path"
    uci set clawpanel.main.port="$port"
    uci set clawpanel.main.version="$version"
    uci commit clawpanel
    echo "UCI configuration saved"
}

# Main setup function
do_setup() {
    local cp_install_path="${CP_BASE_PATH}/clawpanel"
    local cp_data="${CP_BASE_PATH}/clawpanel/data"
    local cp_binary="${cp_install_path}/clawpanel"
    local cp_port="${CP_PORT:-19527}"

    echo "=== ClawPanel Setup ==="
    echo "Install path: $cp_install_path"
    echo "Data path: $cp_data"
    echo "OpenClaw data path: ${CP_OPENCLAW_DIR:-${cp_data}/.openclaw}"
    echo "Port: $cp_port"
    echo "Architecture: $CP_ARCH"
    echo "Version: $CP_VERSION"

    # Check disk space (need ~100MB)
    check_disk "$CP_BASE_PATH" 100 || exit 1

    # Create directories (pass OpenClaw dir if set)
    create_dirs "$CP_BASE_PATH" "$cp_data" "${CP_OPENCLAW_DIR:-${cp_data}/.openclaw}"

    # Determine version
    local ver="$CP_VERSION"
    if [ "$ver" = "latest" ] || [ -z "$ver" ]; then
        echo "Detecting latest version..."
        # Fetch latest version from GitHub API
        ver=$(curl -sL "https://api.github.com/repos/zhaoxinyi02/ClawPanel/releases/latest" 2>/dev/null | grep '"tag_name"' | head -1 | cut -d'"' -f4)
        if [ -z "$ver" ]; then
            ver="pro-v5.3.3"
        fi
        echo "Latest version: $ver"
    fi

    # Download binary
    local download_url=$(get_download_url "$ver" "$CP_ARCH")
    download_binary "$download_url" "$cp_binary" || exit 1

    # Get actual version
    local actual_ver=$("$cp_binary" --version 2>/dev/null | head -1 || echo "$ver")
    echo "ClawPanel version: $actual_ver"
    echo "$actual_ver" > "${cp_install_path}/.version"

    # Save OpenClaw data path to file if specified
    if [ -n "$CP_OPENCLAW_DIR" ]; then
        echo "$CP_OPENCLAW_DIR" > "${cp_install_path}/.openclaw_path"
        echo "OpenClaw data path saved: $CP_OPENCLAW_DIR"
    fi

    # Setup UCI
    setup_uci "$CP_BASE_PATH" "$cp_port" "$actual_ver"

    # Enable and start service
    echo "Enabling service..."
    /etc/init.d/clawpanel enable 2>/dev/null
    /etc/init.d/clawpanel start >/dev/null 2>&1

    echo "ClawPanel installation successful!"
    echo "Installed at: $cp_binary"
    echo "Data at: $cp_data"
    echo "Port: $cp_port"
}

# Main entry
case "${1:-setup}" in
    setup)
        do_setup
        ;;
    *)
        echo "Usage: $0 [setup]"
        exit 1
        ;;
esac
