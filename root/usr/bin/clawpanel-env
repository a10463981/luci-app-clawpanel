#!/bin/sh
# clawpanel-env - auto install ClawPanel from GitHub releases
# Env vars:
#   CP_BASE_PATH      installation base path, default /mnt/sda1
#   CP_VERSION        optional fixed version like pro-v5.3.3; empty/latest = detect latest pro
#   CP_OPENCLAW_DIR   optional OpenClaw data dir

set -e

CP_BASE_PATH="${CP_BASE_PATH:-/mnt/sda1}"
CP_VERSION="${CP_VERSION:-latest}"
CP_OPENCLAW_DIR="${CP_OPENCLAW_DIR:-}"

[ "$(id -u)" = "0" ] || { echo "Error: must run as root"; exit 1; }

get_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64) echo "amd64" ;;
        armv7l|armv7) echo "armv7" ;;
        armv6l|armv6) echo "armv6" ;;
        i386|i686) echo "amd64" ;;
        *) echo "" ;;
    esac
}

CP_ARCH="$(get_arch)"
[ -n "$CP_ARCH" ] || { echo "Error: unsupported arch: $(uname -m)"; exit 1; }

check_disk() {
    local path="$1"
    local needed_mb="${2:-100}"
    if [ -d "$path" ]; then
        local avail_mb
        avail_mb=$(df -m "$path" 2>/dev/null | tail -1 | awk '{print $4}')
        if [ -n "$avail_mb" ] && [ "$avail_mb" -lt "$needed_mb" ]; then
            echo "Error: not enough disk space. Available ${avail_mb}MB, need ${needed_mb}MB"
            return 1
        fi
    fi
}

is_elf() {
    [ -f "$1" ] || return 1
    local first4
    first4=$(od -A n -t x1 -N 4 "$1" 2>/dev/null | tr -d ' \n\r')
    [ "$first4" = "7f454c46" ]
}

get_latest_pro_version() {
    if [ -n "$CP_VERSION" ] && [ "$CP_VERSION" != "latest" ]; then
        printf '%s' "$CP_VERSION"
        return
    fi
    local ver
    ver=$(curl -sL --max-time 10 "https://api.github.com/repos/zhaoxinyi02/ClawPanel/releases" 2>/dev/null \
        | grep '"tag_name"' | cut -d'"' -f4 | grep '^pro-' | head -1 || true)
    if [ -z "$ver" ]; then
        printf '%s' "pro-v5.3.3"
    else
        printf '%s' "$ver"
    fi
}

get_download_url() {
    local ver="$1"
    local arch="$2"
    local file_ver
    file_ver=$(echo "$ver" | sed 's/^pro-v/v/;s/^lite-v/v/')
    printf '%s' "https://github.com/zhaoxinyi02/ClawPanel/releases/download/${ver}/clawpanel-${file_ver}-linux-${arch}"
}

download_binary() {
    local url="$1"
    local dest="$2"
    local tmpfile="/tmp/clawpanel_download_$$"
    echo "Downloading from: $url"

    local http_code
    http_code=$(curl -sL --fail --connect-timeout 15 --max-time 1800 -o "$tmpfile" -w "%{http_code}" "$url" 2>/dev/null || true)
    if [ "$http_code" != "200" ]; then
        rm -f "$tmpfile"
        echo "Error: download failed (HTTP ${http_code:-unknown})"
        return 1
    fi

    local fsize
    fsize=$(wc -c < "$tmpfile" 2>/dev/null || echo 0)
    if [ -z "$fsize" ] || [ "$fsize" -lt 5000000 ]; then
        rm -f "$tmpfile"
        echo "Error: downloaded file too small (${fsize} bytes)"
        return 1
    fi

    if ! is_elf "$tmpfile"; then
        rm -f "$tmpfile"
        echo "Error: downloaded file is not a valid ELF binary"
        return 1
    fi

    mv -f "$tmpfile" "$dest"
    chmod +x "$dest"
    echo "Downloaded: $(echo "$fsize" | awk '{printf "%.1f MB", $1/1024/1024}') → $dest"
}

setup_uci() {
    local install_path="$1"
    local port="$2"
    local version="$3"
    uci set clawpanel.main.enabled='1'
    uci set clawpanel.main.install_path="$install_path"
    uci set clawpanel.main.port="$port"
    uci set clawpanel.main.version="$version"
    if [ -n "$CP_OPENCLAW_DIR" ]; then
        uci set clawpanel.main.openclaw_dir="$CP_OPENCLAW_DIR"
    fi
    uci commit clawpanel
}

do_setup() {
    local cp_install_path="${CP_BASE_PATH}/clawpanel"
    local cp_data="${cp_install_path}/data"
    local cp_binary="${cp_install_path}/clawpanel"
    local cp_port="${CP_PORT:-19527}"
    local openclaw_dir="${CP_OPENCLAW_DIR:-${cp_data}/.openclaw}"

    echo "=== ClawPanel Setup ==="
    echo "Install path: $cp_install_path"
    echo "Data path: $cp_data"
    echo "OpenClaw data path: $openclaw_dir"
    echo "Port: $cp_port"
    echo "Architecture: $CP_ARCH"

    check_disk "$CP_BASE_PATH" 100 || exit 1
    mkdir -p "$CP_BASE_PATH" "$cp_install_path" "$cp_data" "$openclaw_dir"
    echo "Directories created:"
    echo "  - $CP_BASE_PATH"
    echo "  - $cp_data"
    echo "  - $openclaw_dir"

    echo "Detecting latest pro version..."
    local version
    version=$(get_latest_pro_version)
    echo "Using version: $version"

    local url
    url=$(get_download_url "$version" "$CP_ARCH")
    download_binary "$url" "$cp_binary" || exit 1

    local actual_ver
    actual_ver=$("$cp_binary" --version 2>/dev/null | head -1 || echo "$version")
    echo "$actual_ver" > "${cp_install_path}/.version"
    if [ -n "$CP_OPENCLAW_DIR" ]; then
        echo "$CP_OPENCLAW_DIR" > "${cp_install_path}/.openclaw_path"
    fi

    setup_uci "$CP_BASE_PATH" "$cp_port" "$actual_ver"

    echo "Starting ClawPanel..."
    /etc/init.d/clawpanel enable 2>/dev/null || true
    /etc/init.d/clawpanel start >/dev/null 2>&1 || true

    echo "ClawPanel installation successful!"
    echo "Installed at: $cp_binary"
    echo "Data at: $cp_data"
    echo "Port: $cp_port"
}

case "${1:-setup}" in
    setup) do_setup ;;
    *) echo "Usage: $0 [setup]"; exit 1 ;;
esac
